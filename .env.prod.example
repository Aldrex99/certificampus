FRONTEND_PORT=5003
BACKEND_PORT=5004

# Database
MONGO_ROOT_USERNAME=changeme
MONGO_ROOT_PASSWORD=changeme
MONGO_DB_NAME=certificampus

# Backend
CLIENT_URL=https://app.example.com
PUBLIC_URL=https://app.example.com
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_RESET_EXPIRES_IN=1h
JWT_ACTIVATION_EXPIRES_IN=24h

# Email (SparkPost)
SPARKPOST_API_KEY=
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=CertifiCampus

# Stripe (TEST keys, used even in production for live demos).
# Leave empty to run billing in self-contained "mock" mode (no Stripe call).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
